{
  "schemaVersion": 1,
  "id": "remnants_blocks",
  "version": "${version}",
  "name": "Remnants Building Blocks",
  "description": "Adds dirt, grass, podzol, amethyst, obsidian, and all 16 concrete slabs via Polymer (server-side only).",
  "authors": [
    "The Remnants"
  ],
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": [
      "net.remnants.moreslabs.MoreSlabs"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=26.1",
    "fabric-api": "*",
    "polymer-core": "*",
    "polymer-blocks": "*",
    "polymer-resource-pack": "*"
  }
}
