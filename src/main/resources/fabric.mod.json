{
  "schemaVersion": 1,
  "id": "remnants_blocks",
  "version": "${version}",
  "name": "Remnants Building Blocks",
  "description": "Adds dirt, grass (12 color variants), podzol, amethyst, obsidian, concrete, and terracotta slabs via Polymer (server-side only). Includes Jade tooltip integration.",
  "authors": [
    "The Remnants"
  ],
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": [
      "net.remnants.moreslabs.MoreSlabs"
    ],
    "jade": [
      "net.remnants.moreslabs.compat.JadePlugin"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=26.1",
    "fabric-api": "*",
    "polymer-core": "*",
    "polymer-blocks": "*",
    "polymer-resource-pack": "*"
  },
  "suggests": {
    "jade": "*"
  }
}
